CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
GEOBLOCK_URL=https://polymarket.com/api/geoblock
CHAIN_ID=137
BOT_MODE=live
DRY_RUN=true
# If true, live mode aborts startup when Polymarket reports the current IP is geoblocked.
ENFORCE_GEOBLOCK=true
LOG_LEVEL=info
LOG_DIR=./data
MARKET_PAGE_SIZE=200
MAX_MARKETS=200
MIN_MARKET_LIQUIDITY=250
POLLING_INTERVAL_MS=250
HEARTBEAT_INTERVAL_MS=10000
# CLOB trading heartbeat is only started for live resting-order modes (for example GTC).
TRADING_HEARTBEAT_INTERVAL_MS=5000
WS_RECONNECT_BASE_MS=1000
WS_RECONNECT_MAX_MS=15000
MARKET_SUBSCRIPTION_CHUNK_SIZE=250
BOOK_SEED_CONCURRENCY=20
FEE_CACHE_TTL_MS=300000
BALANCE_CACHE_TTL_MS=5000
# Net profit threshold compares after fees + gas + estimated slippage across both legs.
MIN_PROFIT_THRESHOLD=0.005
ARBITRAGE_BUFFER=0.002
MAX_TRADE_SIZE=50
MAX_OPEN_NOTIONAL=200
MAX_BOOK_AGE_MS=300
SLIPPAGE_TOLERANCE=0.01
HEDGE_SLIPPAGE_TOLERANCE=0.02
MIN_ORDERBOOK_LEVELS=1
EXECUTION_ORDER_TYPE=FOK
# Binary arb keeps its own execution-mode flag so FOK remains the default before any FAK experiment.
BINARY_ARB_EXECUTION_MODE=FOK
EXECUTION_TIMEOUT_MS=1500
# In paper mode, wait this long and re-check the live book before counting a shadow fill as successful.
PAPER_SHADOW_LATENCY_MS=150
OPPORTUNITY_COOLDOWN_MS=3000
GAS_COST_USD=0.05
KILL_SWITCH_425_PAUSE_MS=5000
KILL_SWITCH_429_PAUSE_MS=15000
KILL_SWITCH_503_PAUSE_MS=60000
ALLOW_FEE_MARKETS=true
ENABLE_ORDERBOOK_PERSISTENCE=false
BACKTEST_FILE=./data/orderbooks.ndjson
BACKTEST_MAX_LINES=0
RECONCILE_POLL_INTERVAL_MS=2000
RECONCILE_MAX_ATTEMPTS=3
HEALTH_PORT=3001
LOG_MAX_FILE_SIZE_MB=50
LOG_MAX_ROTATED_FILES=7
ENABLE_BINARY_CEILING_STRATEGY=false
ENABLE_NEG_RISK_STRATEGY=false
ENABLE_LATE_RESOLUTION_STRATEGY=false
LATE_RESOLUTION_SIGNAL_FILE=./data/resolution-signals.ndjson
LATE_RESOLUTION_MAX_SIGNAL_AGE_MS=900000
# ─── Temporal Arbitrage (CEX Lag Strategy) ───────────────────────────────────
# Exploits Polymarket price lag behind real-time CEX spot prices.
# Detects when a crypto candle resolution is effectively determined before
# Polymarket reprices, then buys the likely winning side at a discount.
#
# LATENCY NOTE: This strategy is designed for 500ms-8s lag windows and can run
# locally. Adjust TEMPORAL_ARB_ESTIMATED_LATENCY_MS to your measured round-trip
# latency. Run `npm run latency:measure` to estimate it.
ENABLE_TEMPORAL_ARB_STRATEGY=false
ENABLE_CEX_PRICE_FEED=false
CEX_PRIMARY_EXCHANGE=binance
CEX_SYMBOLS=BTC,ETH,SOL
CEX_FEED_STALE_THRESHOLD_MS=3000
CEX_FEED_RECONNECT_BASE_MS=1000
CEX_FEED_RECONNECT_MAX_MS=15000
MIN_TEMPORAL_ARB_CONFIDENCE=0.82
MAX_TEMPORAL_ARB_TRADE_SIZE=30
TEMPORAL_ARB_COOLDOWN_MS=8000
TEMPORAL_ARB_MIN_TIME_REMAINING_MS=8000
TEMPORAL_ARB_MAX_LOOKAHEAD_MS=600000
TEMPORAL_ARB_MAX_SPOT_AGE_MS=2000
TEMPORAL_ARB_ESTIMATED_LATENCY_MS=250
# Live CTF settlement uses Polygon RPC for merge/split/redeem after full-set fills.
POLYGON_RPC_URL=
AUTO_MERGE_BINARY_ARB=true
AUTO_SPLIT_BINARY_CEILING=true
AUTO_CONVERT_NEG_RISK=true
CTF_CONTRACT_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
USDC_COLLATERAL_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296
# If true, PRIVATE_KEY is loaded from GCP Secret Manager instead of the local env file.
USE_GCP_SECRET_MANAGER=false
GCP_PRIVATE_KEY_SECRET_NAME=
PRIVATE_KEY=
POLY_SIGNATURE_TYPE=0
FUNDER_ADDRESS=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
API_KEY_NONCE=
WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
