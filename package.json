{
  "name": "polymarket-arbitrage-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-oriented Polymarket arbitrage bot built with Node.js and TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/main.js",
    "dev:watch": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "backtest": "tsx src/main.ts --mode=backtest",
    "report": "npm run build && node dist/report.js",
    "test": "vitest run",
    "security:check": "node scripts/security-check.mjs",
    "pm2:start": "npm run build && node scripts/pm2-runner.mjs start ecosystem.config.cjs",
    "pm2:stop": "node scripts/pm2-runner.mjs delete polymkt-arb",
    "pm2:logs": "node scripts/pm2-runner.mjs logs polymkt-arb"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "dotenv": "^17.2.3",
    "ethers": "^6.0.0",
    "pino": "^9.12.0",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "optionalDependencies": {
    "@google-cloud/secret-manager": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.1",
    "pm2": "^5.4.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
