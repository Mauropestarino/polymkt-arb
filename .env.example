CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
CHAIN_ID=137
BOT_MODE=live
DRY_RUN=true
LOG_LEVEL=info
LOG_DIR=./data
MARKET_PAGE_SIZE=200
MAX_MARKETS=0
MIN_MARKET_LIQUIDITY=250
POLLING_INTERVAL_MS=250
HEARTBEAT_INTERVAL_MS=10000
WS_RECONNECT_BASE_MS=1000
WS_RECONNECT_MAX_MS=15000
MARKET_SUBSCRIPTION_CHUNK_SIZE=250
BOOK_SEED_CONCURRENCY=20
FEE_CACHE_TTL_MS=300000
BALANCE_CACHE_TTL_MS=5000
# Net profit threshold compares after fees + gas + estimated slippage across both legs.
MIN_PROFIT_THRESHOLD=0.005
ARBITRAGE_BUFFER=0.002
MAX_TRADE_SIZE=50
MAX_OPEN_NOTIONAL=200
SLIPPAGE_TOLERANCE=0.01
HEDGE_SLIPPAGE_TOLERANCE=0.02
MIN_ORDERBOOK_LEVELS=1
EXECUTION_ORDER_TYPE=FOK
EXECUTION_TIMEOUT_MS=1500
OPPORTUNITY_COOLDOWN_MS=3000
GAS_COST_USD=0.05
ALLOW_FEE_MARKETS=true
ENABLE_ORDERBOOK_PERSISTENCE=false
BACKTEST_FILE=./data/orderbooks.ndjson
BACKTEST_MAX_LINES=0
HEALTH_PORT=3001
LOG_MAX_FILE_SIZE_MB=50
LOG_MAX_ROTATED_FILES=7
ENABLE_LATE_RESOLUTION_STRATEGY=true
LATE_RESOLUTION_SIGNAL_FILE=./data/resolution-signals.ndjson
LATE_RESOLUTION_MAX_SIGNAL_AGE_MS=900000
# If true, PRIVATE_KEY is loaded from GCP Secret Manager instead of the local env file.
USE_GCP_SECRET_MANAGER=false
GCP_PRIVATE_KEY_SECRET_NAME=
PRIVATE_KEY=
POLY_SIGNATURE_TYPE=0
FUNDER_ADDRESS=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
API_KEY_NONCE=
WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
